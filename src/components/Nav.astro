---
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="brand" aria-label="halpme home">
      <span class="chev">&#10095;</span>halpme<span class="hm-cursor" aria-hidden="true"></span>
    </a>
    <nav aria-label="Site navigation">
      <a href="#install">Install</a>
      <a href="https://github.com/halpme-sh/halpme" target="_blank" rel="noopener noreferrer" class="gh-link">
        GitHub <span aria-hidden="true">&#8599;</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(246, 241, 233, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 13px;
    padding-bottom: 13px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 2px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--ink);
  }

  .brand .chev {
    color: var(--accent);
    margin-right: 4px;
  }

  .brand .hm-cursor {
    width: 0.52em;
    height: 1.05em;
    margin-left: 2px;
    transform: translateY(1px);
  }

  nav {
    display: flex;
    align-items: center;
    gap: 28px;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-soft);
  }

  nav a {
    text-decoration: none;
    transition: color 0.15s;
  }

  nav a:hover {
    color: var(--ink);
  }

  .gh-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-mono);
    font-size: 13px;
    border: 1px solid var(--ink);
    border-radius: 8px;
    padding: 6px 13px;
    color: var(--ink) !important;
  }

  .gh-link span {
    color: var(--accent);
  }

  @media (max-width: 600px) {
    nav a:not(.gh-link) {
      display: none;
    }
  }
</style>
