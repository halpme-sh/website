{
  "$meta": {
    "name": "halpme",
    "tagline": "Terminal help for your setup",
    "version": "1.0",
    "license": "MIT",
    "colorAuthoringSpace": "oklch"
  },
  "color": {
    "accent":          { "hex": "#E0654A", "oklch": "0.68 0.15 35",  "role": "brand + primary action (coral)" },
    "accentStrong":    { "hex": "#C9512F", "role": "coral text on light surfaces" },
    "accent2":         { "hex": "#1F9E86", "oklch": "0.68 0.12 175", "role": "keywords / matches / success (teal)" },
    "accent2Strong":   { "hex": "#177A68", "role": "teal text on light surfaces" },
    "ink":             { "hex": "#211E1B", "oklch": "0.24 0.008 60", "role": "body text / dark surfaces" },
    "inkSoft":         { "hex": "#4A443E", "role": "secondary text" },
    "paper":           { "hex": "#F6F1E9", "oklch": "0.96 0.010 85", "role": "page background" },
    "paperRaised":     { "hex": "#FCFAF5", "role": "cards / raised surfaces" },
    "border":          { "hex": "#E4DCCF", "role": "hairlines / card borders" },
    "borderSoft":      { "hex": "#EDE6DA", "role": "internal dividers" },
    "muted":           { "hex": "#6E665C", "role": "muted body" },
    "muted2":          { "hex": "#8A8275", "role": "captions" },
    "muted3":          { "hex": "#9B9384", "role": "faint labels" },
    "neutralRamp": {
      "50":  "#FCFAF5",
      "100": "#EDE6DA",
      "200": "#D8CFBF",
      "400": "#B4AA98",
      "500": "#8A8275",
      "600": "#5A544B",
      "800": "#3A352F",
      "900": "#211E1B"
    },
    "tint": {
      "coralBg":   "#FBEAE5",
      "coralText": "#C9512F",
      "tealBg":    "#E4F4EE",
      "tealText":  "#177A68",
      "doBg":      "#F1F8F4",
      "doBorder":  "#C8E0D6",
      "dontBg":    "#FBF1EE",
      "dontBorder":"#E9CFC8"
    },
    "terminal": {
      "bg":       "#1B1916",
      "titlebar": "#22201C",
      "inset":    "#15130F",
      "border":   "#2E2A25",
      "text":     "#E9E2D6",
      "dim":      "#7E776B",
      "dotRed":   "#FF5F57",
      "dotYellow":"#FEBC2E",
      "dotGreen": "#28C840"
    }
  },
  "font": {
    "mono":    "'Monaspace Neon', ui-monospace, SFMono-Regular, Menlo, monospace",
    "sans":    "'Hanken Grotesk', system-ui, -apple-system, sans-serif",
    "display": "'Hanken Grotesk', system-ui, sans-serif",
    "weights": { "mono": [400, 500, 700], "sans": [400, 500, 600, 700, 800] }
  },
  "type": {
    "wordmark": { "size": 64, "font": "mono", "weight": 700, "tracking": "-0.04em", "case": "lower" },
    "display":  { "size": 48, "font": "sans", "weight": 700, "tracking": "-0.03em", "lineHeight": 1.1 },
    "h2":       { "size": 34, "font": "sans", "weight": 700, "tracking": "-0.02em", "lineHeight": 1.18 },
    "h3":       { "size": 21, "font": "sans", "weight": 600 },
    "body":     { "size": 16, "font": "sans", "weight": 400, "lineHeight": 1.6 },
    "small":    { "size": 14, "font": "sans", "weight": 400 },
    "caption":  { "size": 13, "font": "mono", "weight": 400, "lineHeight": 1.7 },
    "label":    { "size": 11, "font": "mono", "weight": 500, "tracking": "0.14em", "case": "upper" }
  },
  "radius": {
    "chip": 7, "input": 10, "button": 9, "card": 14, "terminal": 13, "appIcon": 24, "pill": 20
  },
  "spacing": {
    "container": 1140, "containerPad": 40, "sectionPadY": 84,
    "scale": [4, 8, 12, 16, 20, 26, 40]
  },
  "shadow": {
    "terminal": "0 30px 70px -28px rgba(33,30,27,0.55)",
    "card": "0 1px 3px rgba(33,30,27,0.06)"
  },
  "motion": {
    "cursorBlink": { "duration": "1.1s", "timing": "steps(1,end)", "iteration": "infinite" }
  }
}
